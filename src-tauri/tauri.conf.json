{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZippyMesh",
  "version": "1.0.0",
  "identifier": "com.zippy.mesh",
  "build": {
    "frontendDist": "http://localhost:20128",
    "devUrl": "http://localhost:20128",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "ZippyMesh LLM Router",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/zippy-node"
    ],
    "resources": {
      "resources/standalone/**/*": "standalone/"
    },
    "copyright": "© 2026 Zippy Technologies",
    "homepage": "https://zippymesh.com",
    "shortDescription": "Standalone AI routing gateway with P2P mesh networking",
    "category": "DeveloperTool",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "startMenuFolder": "ZippyMesh"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    }
  }
}
