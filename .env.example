# ZippyMesh Production Configuration
# First-time: run `npm run setup` to generate .env (or copy this file and override).
#
# Secrets policy: Do NOT put OAuth client secrets or tokens in .env. They are provisioned
# in the dashboard and stored in DATA_DIR (oauth-secrets.json, db.json). Only the two
# bootstrap values below are read from env; override them for production.

# Main API Port
ZIPPY_PORT=20128

# Internal API base URL (for peers/filtered to fetch network status).
# When unset, uses http://localhost:ZIPPY_PORT. Set if status is on another host.
# INTERNAL_API_URL=http://localhost:20128

# P2P Discovery Port (UDP)
ZIPPY_DISCOVERY_PORT=20129

# P2P Beacon Interval (ms)

# Auth (required for production; override these)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_32_RANDOM_CHARS_MINIMUM
# Set a strong password for the admin account
INITIAL_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Custom Data Directory (Optional)
DATA_DIR=./data

# Plugins (comma-separated: llm, dvpn, compute). Default: llm
# ENABLED_PLUGINS=llm

# Node Branding
ZIPPY_NODE_NAME=ZippyNode

# ============================================================
# OAuth App-Level Credentials (required to enable OAuth flows)
# ============================================================
# These are APPLICATION credentials (same for all ZMLR users),
# not user credentials. Required once per deployment.
# See docs/oauth-setup.md for how to obtain these values.
#
# After setting these, user tokens are stored in DATA_DIR
# (oauth-secrets.json, encrypted) and survive rebuilds.
#
# Antigravity (Google Gemini Code Assist) OAuth app secret:
ANTIGRAVITY_CLIENT_SECRET=
#
# Gemini CLI OAuth app secret (used by both 'gemini' and 'gemini-cli' providers):
GEMINI_CLIENT_SECRET=
#
# iFlow OAuth app secret (only needed if using iFlow provider):
IFLOW_CLIENT_SECRET=

# Required: Secret key used to sign and verify API keys for the /v1/* endpoint.
# Without this, the router falls back to an ephemeral randomly-generated value that
# changes on every restart (a warning is logged). Set this before exposing ZMLR to
# any network or tool that needs a stable API key.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_SECRET=

# Optional: ZippyCoin node RPC endpoint (Chain ID: 947)

# Optional: Prompt cache settings
# Set to "false" to disable exact-match prompt caching entirely
PROMPT_CACHE_ENABLED=true
# Cache TTL in seconds (default: 3600 = 1 hour). Set to 0 for no expiry.
PROMPT_CACHE_TTL=3600

# Optional: OpenRouter API key — gives access to 300+ models via a single key
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=


# Community Edition
ZIPPYMESH_EDITION=community
