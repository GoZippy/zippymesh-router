# ZippyMesh LLM Router - Environment Configuration Example
# Copy this file to .env.local and fill in your values.
# DO NOT COMMIT .env.local TO VERSION CONTROL.

# --- ZippyCoin Node Configuration ---
ZIPPY_NODE_BIN=./sidecar/zippy-node
ZIPPY_RPC_PORT=8545
ZIPPY_API_PORT=9480

# --- Third-Party OAuth Secrets (Move these here from oauth.js) ---
# Anthropic / Claude
CLAUDE_CLIENT_ID=your_id_here

# OpenAI / Codex
CODEX_CLIENT_ID=your_id_here

# Google / Gemini
GEMINI_CLIENT_ID=your_id_here
GEMINI_CLIENT_SECRET=your_secret_here

# GitHub / Copilot
GITHUB_CLIENT_ID=your_id_here

# iFlow
IFLOW_CLIENT_ID=your_id_here
IFLOW_CLIENT_SECRET=your_secret_here

# Antigravity (Google Provider)
ANTIGRAVITY_CLIENT_ID=your_id_here
ANTIGRAVITY_CLIENT_SECRET=your_secret_here

# --- Application Settings ---
DATA_DIR=./data
NODE_ENV=development
ENABLE_REQUEST_LOGS=true
