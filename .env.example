# ZippyMesh Production Configuration
# First-time: run `npm run setup` to generate .env with secrets (or copy this file and override).
# Override JWT_SECRET, INITIAL_PASSWORD, API_KEY_SECRET, MACHINE_ID_SALT for production.

# Main API Port
ZIPPY_PORT=20128

# Internal API base URL (for peers/filtered to fetch network status).
# When unset, uses http://localhost:ZIPPY_PORT. Set if status is on another host.
# INTERNAL_API_URL=http://localhost:20128

# P2P Discovery Port (UDP)
ZIPPY_DISCOVERY_PORT=20129

# P2P Beacon Interval (ms)
ZIPPY_BEACON_INTERVAL=30000

# Auth (required for production; override these)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_32_RANDOM_CHARS_MINIMUM
# Set a strong password for the admin account
INITIAL_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Custom Data Directory (Optional)
DATA_DIR=./data

# Plugins (comma-separated: llm, dvpn, compute). Default: llm
# ENABLED_PLUGINS=llm

# Node Branding
ZIPPY_NODE_NAME=ZippyNode

# OAuth provider secrets (required for Connect Antigravity / Gemini-style flows)
# Get client ID and secret from Google Cloud Console (OAuth 2.0 credentials).
# ANTIGRAVITY_CLIENT_ID=your-antigravity-client-id.apps.googleusercontent.com
# ANTIGRAVITY_CLIENT_SECRET=your-antigravity-client-secret
